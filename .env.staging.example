# .env.staging.example
#
# 1. Copy to .env.staging  (gitignored — NEVER commit the populated file).
# 2. Fill in every value below. Blank values STOP the automated deploy.
# 3. Run: bash scripts/deploy-staging.sh
#
# Values are sourced from this file, pushed to AWS SSM via `sst secret set`
# (encrypted at rest), then read by the Lambda at cold start. Lifecycle:
#   .env.staging  →  SSM SecureString  →  Lambda env  →  app
#
# See docs/ENV.md for what each one means and how to obtain it.

# ─── Neon Postgres ───────────────────────────────────────────────────────
# POOLED endpoint (host contains "-pooler"). Lambda uses this at runtime.
DATABASE_URL=
# DIRECT (non-pooled) endpoint. Used ONLY by drizzle-kit migrations.
DATABASE_URL_DIRECT=

# ─── Resend (transactional email) ────────────────────────────────────────
# API key from https://resend.com/api-keys.
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@publicpulse.com.bd
RESEND_REPLY_TO=info@publicpulse.com.bd

# ─── BetterAuth ──────────────────────────────────────────────────────────
# 32+ byte random string. Generate locally with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── /manage admin (single user) ─────────────────────────────────────────
# Email + PLAINTEXT password. The Lambda hashes the password with scrypt on
# first /manage hit (via BetterAuth's hashPassword) and writes the hash to
# Postgres. Do NOT pre-hash — algorithm mismatch will break sign-in.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Public site URL for this stage ──────────────────────────────────────
# Leave as the CloudFront URL printed by SST after the first deploy.
# For first run, leave it blank — the deploy script will write it back.
NEXT_PUBLIC_SITE_URL=
