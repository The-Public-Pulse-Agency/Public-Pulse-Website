# Copy to .env.local (gitignored) for local dev. Never commit real values.
# In production, source from SSM Parameter Store (SecureString) — see docs/ARCHITECTURE.md.

# Neon Postgres — serverless. Lambda OUTSIDE VPC, public TLS.
# Get a fresh connection string from https://console.neon.tech → Project → Connect.
# Use the POOLED endpoint (host contains "-pooler") for Lambda; the direct endpoint for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require
# Optional: direct (non-pooled) for `drizzle-kit push` / migrations
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# Site
NEXT_PUBLIC_SITE_URL=https://publicpulse.com.bd
