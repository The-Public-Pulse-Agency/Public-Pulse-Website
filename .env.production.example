# .env.production.example
#
# 1. Copy to .env.production  (gitignored — NEVER commit the populated file).
# 2. Fill in every value below. Blank values STOP the automated deploy.
# 3. Run: bash scripts/deploy.sh production
#
# Values are sourced from this file, pushed to AWS SSM via `sst secret set`
# (encrypted at rest), then read by the Lambda at cold start. Lifecycle:
#   .env.production  →  SSM SecureString  →  Lambda env  →  app
#
# ⚠  This is the production stack. The deploy lands on the SST-managed
#    CloudFront URL ONLY — publicpulse.com.bd is NOT repointed by this script.
#    DNS cutover is a separate manual step in docs/DEPLOY.md.
#
# See docs/ENV.md for what each one means and how to obtain it.

# ─── Neon Postgres ───────────────────────────────────────────────────────
# POOLED endpoint (host contains "-pooler"). Lambda uses this at runtime.
DATABASE_URL=
# DIRECT (non-pooled) endpoint. Used ONLY by drizzle-kit migrations.
DATABASE_URL_DIRECT=

# ─── Resend (transactional email) ────────────────────────────────────────
# API key from https://resend.com/api-keys — generate one scoped to "send"
# only. Domain `publicpulse.com.bd` is already verified (DKIM records live
# under `resend._domainkey.publicpulse.com.bd` in Route 53).
RESEND_API_KEY=
# Sender + reply-to addresses. Both should use @publicpulse.com.bd so DKIM
# alignment holds and the message lands in inbox, not spam.
RESEND_FROM_EMAIL=info@publicpulse.com.bd
RESEND_REPLY_TO=info@publicpulse.com.bd

# ─── BetterAuth ──────────────────────────────────────────────────────────
# 32+ byte random string. Generate locally with:  openssl rand -base64 32
# IMPORTANT: rotating this invalidates every active session in production.
BETTER_AUTH_SECRET=

# ─── /manage admin (single user) ─────────────────────────────────────────
# Email + PLAINTEXT password. The Lambda hashes the password with scrypt on
# first /manage hit (via BetterAuth's hashPassword) and writes the hash to
# Postgres. Do NOT pre-hash — algorithm mismatch will break sign-in.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Public site URL for this stage ──────────────────────────────────────
# For the pre-cutover deploy, use the CloudFront URL printed by SST after
# the first deploy (e.g. https://dXXXXXX.cloudfront.net). The first time
# you run scripts/deploy.sh production this can be left blank — the deploy
# will succeed, then come back, paste in the printed URL, and re-run so
# canonicals/sitemaps/og-urls match where the site is actually served.
#
# After DNS cutover, change this to https://publicpulse.com.bd and redeploy
# so the canonicals point at the apex.
NEXT_PUBLIC_SITE_URL=
